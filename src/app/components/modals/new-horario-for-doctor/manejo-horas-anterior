      <form  style="position: sticky; top: 86px;">
        <div class="row justify-content-center">
              <!-- HORARIO DEL LUNES -->
              <div class="col-12 col-md-10  mb-3 row justify-content-start py-1 py-sm-2 py-md-3 align-items-center card">
                <div class="col-6">
                  <label class="form-label">Horario del Lunes</label>
                </div>
                <div class="col-6">
                  <ul class="list-group list-group-flush">
                  
                    <ng-container *ngFor="let hour of hours | orderHours:'morning':'Monday';let i = index">
                      <li class="list-group-item d-flex justify-content-between" *ngIf="hour.day == 'Monday'">
                        <div class="d-flex flex-column">
                          <span>{{hour.hours}}</span>                         
                        </div>             
                        <button type="button" (click)="deleteHour(hour._id ? hour._id : hour.idTemporal, hour.idTemporal ? true : false)" class="btn btn-icon text-danger"><i class="fas fa-trash"></i></button>
                      </li>
                    </ng-container>
                    
                    <ng-container *ngFor="let hour of hours | orderHours:'afternoon':'Monday';let i = index">
                      <li class="list-group-item d-flex justify-content-between" *ngIf="hour.day == 'Monday'">
                        <div class="d-flex flex-column">
                          <span>{{hour.hours}}</span>
                        </div>
                        <button type="button" (click)="deleteHour(hour._id ? hour._id : hour.idTemporal, hour.idTemporal ? true : false)" class="btn btn-icon text-danger"><i class="fas fa-trash"></i></button>
                      </li>
                    </ng-container>
          
                  </ul>

                  <button class="btn btn-primary btn-sm" type="button" (click)="newHour('Monday')">
                    Agregar nueva hora
                  </button>
                </div>
              </div>
              <!--END  HORARIO DEL LUNES -->

